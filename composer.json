{
    "name": "bitech/illuminate",
    "description": "Illuminate — Bi-Tech Senior Laravel Hiring Challenge",
    "keywords": ["cli", "challenge", "laravel"],
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/database": "^12.56",
        "illuminate/events": "^12.56"
    },
    "require-dev": {
        "illuminate/http": "^12.17",
        "larastan/larastan": "^3.9",
        "laravel-zero/framework": "^12.0.2",
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^3.8.4|^4.1.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "suggest": {
        "ext-pdo_pgsql": "Required for challenge SSH/PostgreSQL commands.",
        "ext-pdo_sqlite": "Required for challenge:geodata-import and challenge:geodata-solve (local cache DB)."
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["illuminate"]
}
